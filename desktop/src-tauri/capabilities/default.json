{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Baseline Flight Deck default capability set — webview, store, and shell open.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:window:default",
    "core:app:default",
    "store:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://mission.baselineautomations.com/**" },
        { "url": "https://staging.baselineautomations.com/**" },
        { "url": "https://docs.baselineautomations.com/**" }
      ]
    }
  ]
}
