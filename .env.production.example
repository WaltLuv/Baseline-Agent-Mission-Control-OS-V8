# ═══════════════════════════════════════════════════════════════════════
# Mission Control V2 — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════
# Copy this to .env.production and fill in ALL CHANGE_ME values.
# NEVER check .env.production into version control.
#
# Generate secure secrets:
#   openssl rand -hex 32   → for AUTH_SECRET
#   openssl rand -hex 16   → for API_KEY
#   openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24 → for AUTH_PASS

MC_VERSION=latest
ENV_FILE=.env.production
PORT=3000

AUTH_USER=admin
AUTH_PASS=CHANGE_ME
API_KEY=CHANGE_ME
AUTH_SECRET=CHANGE_ME

MC_COOKIE_SAMESITE=strict
MC_COOKIE_SECURE=1
MC_ALLOWED_HOSTS=CHANGE_ME_EXAMPLE.COM,127.0.0.1

MC_HOST=CHANGE_ME_EXAMPLE.COM

OPENCLAW_GATEWAY_HOST=host.docker.internal
OPENCLAW_GATEWAY_PORT=18789
NEXT_PUBLIC_GATEWAY_HOST=
NEXT_PUBLIC_GATEWAY_PORT=18789
NEXT_PUBLIC_GATEWAY_PROTOCOL=https
NEXT_PUBLIC_GATEWAY_REVERSE_PROXY=1
NEXT_PUBLIC_GATEWAY_CLIENT_ID=openclaw-control-id
OPENCLAW_HOME=
OPENCLAW_TOOLS_PROFILE=coding

MISSION_CONTROL_DATA_DIR=/app/.data

MC_DEFAULT_GATEWAY_NAME=primary
MC_COORDINATOR_AGENT=coordinator
NEXT_PUBLIC_COORDINATOR_AGENT=coordinator
