# ═══════════════════════════════════════════════════════════════════════
# Mission Control — Production Environment Template (DigitalOcean Droplet)
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env.production ON THE DROPLET and fill every CHANGE_ME.
#   cp .env.production.example .env.production && chmod 600 .env.production
#
# NEVER commit .env.production. NEVER paste real secrets into this template.
# Generate secrets:  openssl rand -hex 32   (AUTH_SECRET, SHARE_SIGNING_SECRET)
#                     openssl rand -hex 16   (API_KEY)
#                     openssl rand -hex 32   (CREDENTIALS_ENCRYPTION_KEY → 64 hex chars)
# ═══════════════════════════════════════════════════════════════════════

# ── DEPLOY / RUNTIME ─────────────────────────────────────────────────────
MC_VERSION=latest
ENV_FILE=.env.production
NODE_ENV=production
PORT=3000
# Host path on the attached DO Block Storage volume (used by docker-compose.droplet.yml).
# Set as a shell env var at deploy time too: export MC_DATA_DIR=/mnt/mc_data
MC_DATA_DIR=/mnt/mc_data

# ── APP URL / DOMAIN ─────────────────────────────────────────────────────
MC_HOST=CHANGE_ME.example.com
APP_URL=https://CHANGE_ME.example.com
NEXT_PUBLIC_APP_URL=https://CHANGE_ME.example.com
MC_PUBLIC_BASE_URL=https://CHANGE_ME.example.com
MC_ALLOWED_HOSTS=CHANGE_ME.example.com,127.0.0.1

# ── AUTH / SESSION ───────────────────────────────────────────────────────
AUTH_USER=admin
AUTH_PASS=CHANGE_ME
AUTH_SECRET=CHANGE_ME_64_HEX          # openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_64_HEX      # openssl rand -hex 32
API_KEY=CHANGE_ME_32_HEX              # openssl rand -hex 16
SHARE_SIGNING_SECRET=CHANGE_ME_64_HEX # openssl rand -hex 32
MC_COOKIE_SECURE=1
MC_COOKIE_SAMESITE=strict
MC_ENABLE_HSTS=1

# ── DATABASE (SQLite — durable via the mounted volume) ───────────────────
# DB resolves to $MISSION_CONTROL_DATA_DIR/mission-control.db inside the container.
# /app/.data is the bind mount → host $MC_DATA_DIR (the attached block volume).
MISSION_CONTROL_DATA_DIR=/app/.data
# (Future Postgres path: add DATABASE_URL here — see deploy doc §"Future: Postgres".)

# ── ENCRYPTION (credentials vault — AES) ─────────────────────────────────
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_64_HEX   # openssl rand -hex 32 (exactly 64 hex chars)

# ── GOOGLE OAUTH (login) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
# Add the production origin (https://CHANGE_ME.example.com) to the OAuth client
# "Authorized JavaScript origins" in Google Cloud Console.

# ── TWILIO (SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── RESEND / SMTP (email + verification) ─────────────────────────────────
# baseline-agents.com is the verified sending domain — use a from-address on it.
RESEND_API_KEY=CHANGE_ME
MC_RESEND_API_KEY=CHANGE_ME
RESEND_FROM=noreply@baseline-agents.com
MC_EMAIL_FROM=noreply@baseline-agents.com
BRIEFING_FROM_EMAIL=noreply@baseline-agents.com
# Optional raw SMTP fallback (leave blank if using Resend):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@baseline-agents.com

# ── STRIPE (credit packages / billing) ──────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME            # sk_live_... (or sk_test_... for validation)
STRIPE_WEBHOOK_SECRET=CHANGE_ME        # whsec_...
NEXT_PUBLIC_STRIPE_LIVE_MODE=true
STRIPE_TEST_MODE=false
# Price IDs (if using subscription price objects):
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=

# ── MODEL PROVIDERS (OpenAI / OpenRouter / Anthropic) ────────────────────
OPENAI_API_KEY=CHANGE_ME
OPENROUTER_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME

# ── VECTOR / MEMORY (optional — Pinecone) ────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=
PINECONE_INDEX_HOST=
PINECONE_EMBED_MODEL=

# ── GATEWAY (OpenClaw — local-only sidecar; safe to leave default) ───────
NEXT_PUBLIC_GATEWAY_OPTIONAL=true
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
MISSION_CONTROL_DATA_DIR=/app/.data

# ── NOTE: VisionOps & PropControl ────────────────────────────────────────
# No VISIONOPS_* or PROPCONTROL_* env vars are referenced in the codebase as
# of this commit. PropControl is linked from the UI as external sites
# (propcontrolempire.com / propcontrol.netlify.app) and needs no server env.
# If integration keys are added later, document them here as placeholders.
