{
  "name": "baseline-agent-os",
  "description": "Baseline Automations — a localhost operator console for your AI agent stack.",
  "author": "Walter Thornton",
  "homepage": "https://github.com/WaltLuv/baseline-agent-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/WaltLuv/baseline-agent-os.git"
  },
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "dev": "bun run seed:data && vite dev --open",
    "build": "bun run seed:data && vite build",
    "build:dev": "bun run seed:data && vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "seed:data": "test -f src/data/live-data.json || cp src/data/live-data.example.json src/data/live-data.json",
    "agent:create": "bun run scripts/create-agent.ts",
    "aggregate": "bun run scripts/aggregate.ts",
    "test:activation-scroll": "bun scripts/test-activation-scroll.mjs",
    "install-dream": "bun run scripts/install-dream-cron.ts",
    "uninstall-dream": "bun run scripts/install-dream-cron.ts --uninstall",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
