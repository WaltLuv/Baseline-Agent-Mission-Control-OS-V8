#!/usr/bin/env bash
# mc — Baseline OS Operator Control Surface (thin shell wrapper).
#
# Resolves to the bun-executed TypeScript implementation so contributors
# can edit the CLI without a build step. Put this directory on PATH:
#
#   export PATH="$HOME/code/claude-os/bin:$PATH"
#
# After that, `mc help` works from anywhere.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if ! command -v bun >/dev/null 2>&1; then
  echo "mc: bun not found on PATH. Install: curl -fsSL https://bun.sh/install | bash" >&2
  exit 127
fi

exec bun run "$REPO_ROOT/scripts/mc.ts" "$@"
