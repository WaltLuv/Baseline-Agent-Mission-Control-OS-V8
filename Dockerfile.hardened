# ═══════════════════════════════════════════════════════════════════════
# Mission Control V2 — Hardened Production Dockerfile
# Multi-stage build: base → deps → build → runtime
# Usage: docker build --no-cache -t mission-control:<tag> --target runtime .
#        docker build --build-arg MC_VERSION=1.2.0 -t mission-control:1.2.0 .
# ═══════════════════════════════════════════════════════════════════════

# ─── Stage 0: Common base ──────────────────────────────────────────────
FROM node:22-slim AS base
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

# ─── Stage 1: Install dependencies ─────────────────────────────────────
FROM base AS deps
COPY package.json pnpm-lock.yaml* ./
# better-sqlite3 requires native compilation tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/*
RUN if [ -f pnpm-lock.yaml ]; then \
      pnpm install --frozen-lockfile; \
    else \
      echo "WARN: pnpm-lock.yaml not found; running non-frozen install" && \
      pnpm install --no-frozen-lockfile; \
    fi

# ─── Stage 2: Build the application ────────────────────────────────────
FROM base AS build
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Run next build (standalone output via next.config.js)
RUN pnpm build

# ─── Stage 3: Production runtime ───────────────────────────────────────
FROM node:22-slim AS runtime

ARG MC_VERSION=dev
LABEL org.opencontainers.image.source="https://github.com/WaltLuv/Baseline-Agent-Mission-Control-OS-V8"
LABEL org.opencontainers.image.description="Mission Control V2 — Operations Dashboard (Hardened)"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.version="${MC_VERSION}"

WORKDIR /app

# ── Runtime packages ────────────────────────────────────────────────────
# curl + ca-certificates for healthchecks and outbound HTTPS
# python3 + make + g++   for native addons needed by agent installers
# git                    for agent runtime installers (OpenClaw, Hermes)
# procps                 provides ps/uptime for system-monitor APIs
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      curl ca-certificates procps \
      python3 git make g++ \
    && rm -rf /var/lib/apt/lists/*

# ── Non-root user ───────────────────────────────────────────────────────
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# ── Copy built artifacts ────────────────────────────────────────────────
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public
COPY --from=build /app/src/lib/schema.sql ./src/lib/schema.sql
COPY --from=build /app/scripts ./scripts

# Copy installed node-pty fully (with native binary artifacts)
COPY --from=deps /app/node_modules/.pnpm/node-pty@1.1.0/node_modules/node-pty \
  ./node_modules/.pnpm/node-pty@1.1.0/node_modules/node-pty

# ── Data directory ──────────────────────────────────────────────────────
RUN mkdir -p .data && chown nextjs:nodejs .data

# ── Healthcheck script ──────────────────────────────────────────────────
COPY <<'EOF' /app/healthcheck.js
const http = require("http");
const port = process.env.PORT || 3000;
const path = "/api/status?action=health";
const r = http.get(`http://localhost:${port}${path}`, (s) => {
  process.exit(s.statusCode === 200 ? 0 : 1);
});
r.on("error", () => process.exit(1));
r.setTimeout(4000, () => { r.destroy(); process.exit(1); });
EOF

# ── Entrypoint ──────────────────────────────────────────────────────────
COPY docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod 755 /app/docker-entrypoint.sh && \
    chmod -R a+rX /app/public/ /app/src/

# ── Drop privileges ─────────────────────────────────────────────────────
USER nextjs

# ── Environment ─────────────────────────────────────────────────────────
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# ── Volume for persistent data (SQLite DB, generated secrets) ───────────
VOLUME ["/app/.data"]

# ── Expose port ─────────────────────────────────────────────────────────
EXPOSE 3000

# ── Health check ────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD ["node", "/app/healthcheck.js"]

# ── Start via entrypoint (handles signal forwarding) ────────────────────
ENTRYPOINT ["/app/docker-entrypoint.sh"]
