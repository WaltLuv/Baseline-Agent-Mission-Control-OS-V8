# ═══════════════════════════════════════════════════════════════════════
# Mission Control V2 — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env.production and fill in ALL values before deploying.
# NEVER commit this file with real secrets.
#
# Usage with docker-compose.production.yml:
#   docker compose -f docker-compose.production.yml \
#     --env-file .env.production up -d
# ═══════════════════════════════════════════════════════════════════════

# ─── Image / Version ───────────────────────────────────────────────────
# Version tag for the built image. Use git SHA or semver in production.
MC_VERSION=latest

# ─── Compose Configuration ─────────────────────────────────────────────
# Docker will look for this file for the production env vars.
ENV_FILE=.env.production

# ─── Server Port ───────────────────────────────────────────────────────
# Internal container port (don't change unless you also update Caddyfile).
PORT=3000

# ═══════════════════════════════════════════════════════════════════════
# Authentication — REQUIRED for production
# ═══════════════════════════════════════════════════════════════════════
# Admin username for first-run seeding
AUTH_USER=admin

# Admin password — use a strong, random password (24+ chars recommended)
AUTH_PASS=CHANGE_ME_USE_A_STRONG_PASSWORD

# If your password contains special characters (e.g. #), use base64 encoding:
# AUTH_PASS_B64=<base64-encoded-password>

# Cryptographic secret for session cookies — use openssl rand -hex 32
# Auto-generated on first run if not set, but for production you SHOULD
# set this explicitly to survive container rebuilds.
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# API key for headless/external/agent access (x-api-key header)
# Use openssl rand -hex 16 or similar for a strong key.
API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_16

# ═══════════════════════════════════════════════════════════════════════
# Cookie / Session Security — Production Hardening
# ═══════════════════════════════════════════════════════════════════════
MC_COOKIE_SAMESITE=strict
MC_COOKIE_SECURE=1

# ═══════════════════════════════════════════════════════════════════════
# Network Access Control
# ═══════════════════════════════════════════════════════════════════════
# Allowed hostnames for the MC server. For production behind a reverse
# proxy, include your public domain name here.
MC_ALLOWED_HOSTS=localhost,127.0.0.1,::1

# ═══════════════════════════════════════════════════════════════════════
# Hosting
# ═══════════════════════════════════════════════════════════════════════
# Public hostname for the Mission Control dashboard (used by Caddy for
# automatic HTTPS via Let's Encrypt).
MC_HOST=CHANGE_ME_EXAMPLE.COM

# ═══════════════════════════════════════════════════════════════════════
# OpenClaw Gateway Configuration
# ═══════════════════════════════════════════════════════════════════════
# Server-side: How Mission Control backend reaches the gateway.
# When gateway runs on the Docker host:
OPENCLAW_GATEWAY_HOST=host.docker.internal
OPENCLAW_GATEWAY_PORT=18789

# Browser-side: How the user's browser reaches the gateway.
# If the gateway is proxied through the reverse proxy at /gw:
# NEXT_PUBLIC_GATEWAY_URL=wss://CHANGE_ME_EXAMPLE.COM/gw
#
# Or if gateway port is directly exposed:
# NEXT_PUBLIC_GATEWAY_HOST=CHANGE_ME_EXAMPLE.COM
# NEXT_PUBLIC_GATEWAY_PORT=18789
#
# If running standalone without a gateway, set:
# NEXT_PUBLIC_GATEWAY_OPTIONAL=true
NEXT_PUBLIC_GATEWAY_HOST=
NEXT_PUBLIC_GATEWAY_PORT=18789
NEXT_PUBLIC_GATEWAY_PROTOCOL=https

# Reverse proxy mode — set to 1 when behind HTTPS reverse proxy
# that also proxies WebSocket connections.
NEXT_PUBLIC_GATEWAY_REVERSE_PROXY=1

NEXT_PUBLIC_GATEWAY_CLIENT_ID=openclaw-control-ui
OPENCLAW_HOME=
OPENCLAW_TOOLS_PROFILE=coding

# ═══════════════════════════════════════════════════════════════════════
# Data Paths
# ═══════════════════════════════════════════════════════════════════════
MISSION_CONTROL_DATA_DIR=/app/.data

# ═══════════════════════════════════════════════════════════════════════
# Data Retention (days, 0 = keep forever)
# ═══════════════════════════════════════════════════════════════════════
# MC_RETAIN_ACTIVITIES_DAYS=90
# MC_RETAIN_AUDIT_DAYS=365
# MC_RETAIN_LOGS_DAYS=30
# MC_RETAIN_NOTIFICATIONS_DAYS=60

# ═══════════════════════════════════════════════════════════════════════
# Google OAuth (optional)
# ═══════════════════════════════════════════════════════════════════════
# GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ═══════════════════════════════════════════════════════════════════════
# Trusted reverse proxy / header authentication (advanced)
# ═══════════════════════════════════════════════════════════════════════
# MC_PROXY_AUTH_HEADER=
# MC_PROXY_AUTH_DEFAULT_ROLE=
# MC_PROXY_AUTH_TRUSTED_IPS=<REQUIRED if MC_PROXY_AUTH_HEADER set>

# ═══════════════════════════════════════════════════════════════════════
# OpenClaw Paths (derived from OPENCLAW_HOME if not set)
# ═══════════════════════════════════════════════════════════════════════
# OPENCLAW_LOG_DIR=
# OPENCLAW_MEMORY_DIR=
# OPENCLAW_SOUL_TEMPLATES_DIR=
# OPENCLAW_BIN=openclaw
# OPENCLAW_CONFIG_PATH=

# ═══════════════════════════════════════════════════════════════════════
# Agents / Provisioning
# ═══════════════════════════════════════════════════════════════════════
MC_DEFAULT_GATEWAY_NAME=primary
MC_COORDINATOR_AGENT=coordinator
NEXT_PUBLIC_COORDINATOR_AGENT=coordinator

# ═══════════════════════════════════════════════════════════════════════
# 1Password Integration (optional)
# ═══════════════════════════════════════════════════════════════════════
# OP_VAULT_NAME=default
